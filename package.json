{
  "name": "movoall",
  "private": true,
  "version": "0.1.0",
  "description": "MOVO Android Rider and Driver apps with Laravel backend.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "rider:start": "npm --workspace apps/rider-android start",
    "driver:start": "npm --workspace apps/driver-android start",
    "rider:android": "npm --workspace apps/rider-android android",
    "driver:android": "npm --workspace apps/driver-android android",
    "backend:serve": "cd backend/laravel-api && php artisan serve",
    "backend:migrate": "cd backend/laravel-api && php artisan migrate"
  }
}
